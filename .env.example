# Copy to .env for local development.
# Never commit real secrets.

ZT_DASHBOARD_HOST=127.0.0.1
ZT_DASHBOARD_PORT=8080
# Required when binding the dashboard to anything other than localhost before the first admin account exists.
ZT_BOOTSTRAP_TOKEN=change-this-local-bootstrap-token
PYTHON_BIN=python

# Optional local defaults for generated scripts and examples.
ZT_NKP_VERSION=v2.17.1
ZT_STANDARD_BUNDLE_PATH=/mnt/c/Share/nkp-bundle_v2.17.1_linux_amd64/nkp-v2.17.1
ZT_AIRGAPPED_BUNDLE_PATH=/mnt/c/Share/nkp-air-gapped-bundle_v2.17.1_linux_amd64/nkp-v2.17.1
