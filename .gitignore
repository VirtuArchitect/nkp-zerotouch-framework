# NKP bundles and extracted artifacts are large external inputs.
*.tar
*.tar.gz
*.tgz
*.zip
nkp-bundle_*/
nkp-air-gapped-bundle_*/

# Local generated output.
.zt/
out/
dist/
logs/
*.kubeconfig
kubeconfig
*.log

# Real secrets must stay local.
configs/secrets/*.secrets.yaml
!configs/secrets/*.secrets.example.yaml
*.env
!*.env.example

# Editor and OS files.
.DS_Store
Thumbs.db
.pytest_cache/
__pycache__/
*.pyc
