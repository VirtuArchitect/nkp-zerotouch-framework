{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/nkp-zerotouch-framework/environment.schema.json",
  "title": "NKP ZeroTouch Environment",
  "type": "object",
  "required": ["environment", "nkp", "nutanix", "cluster"],
  "properties": {
    "environment": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_-]+$"
        },
        "type": {
          "type": "string",
          "enum": ["connected", "proxied", "air-gapped"]
        },
        "provider": {
          "type": "string",
          "enum": ["nutanix-ahv", "air-gapped-ahv", "proxied-ahv", "bare-metal"]
        },
        "proxy": {
          "type": "object",
          "properties": {
            "httpProxy": { "type": "string" },
            "httpsProxy": { "type": "string" },
            "noProxy": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "nkp": {
      "type": "object",
      "required": ["version"],
      "properties": {
        "version": { "type": "string" },
        "bundleType": {
          "type": "string",
          "enum": ["standard", "air-gapped"]
        },
        "bundlePath": { "type": "string" },
        "cliPath": { "type": "string" },
        "kubectlPath": { "type": "string" }
      }
    },
    "nutanix": {
      "type": "object",
      "required": ["prismCentralEndpoint", "clusterName"],
      "properties": {
        "prismCentralEndpoint": { "type": "string" },
        "clusterName": { "type": "string" },
        "subnetName": { "type": "string" },
        "imageName": { "type": "string" },
        "storageContainer": { "type": "string" },
        "project": { "type": "string" }
      }
    },
    "registry": {
      "type": "object",
      "properties": {
        "endpoint": { "type": "string" },
        "namespace": { "type": "string" },
        "insecure": { "type": "boolean" },
        "caCert": { "type": "string" },
        "pushConcurrency": { "type": "integer", "minimum": 1 },
        "onExistingTag": {
          "type": "string",
          "enum": ["overwrite", "error", "skip"]
        }
      }
    },
    "cluster": {
      "type": "object",
      "required": ["name", "kubernetesVersion"],
      "properties": {
        "name": { "type": "string" },
        "kubernetesVersion": { "type": "string" },
        "controlPlaneReplicas": { "type": "integer", "minimum": 1 },
        "workerReplicas": { "type": "integer", "minimum": 0 },
        "podCidr": { "type": "string" },
        "serviceCidr": { "type": "string" },
        "controlPlaneEndpointIp": { "type": "string" },
        "controlPlaneEndpointPort": { "type": "integer", "minimum": 1 },
        "loadBalancerIpRange": { "type": "string" },
        "ntpServers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sshPublicKeyFile": { "type": "string" },
        "sshUsername": { "type": "string" },
        "selfManaged": { "type": "boolean" },
        "fips": { "type": "boolean" }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "environment": {
            "properties": {
              "type": { "const": "air-gapped" }
            }
          }
        }
      },
      "then": {
        "required": ["registry"],
        "properties": {
          "nkp": {
            "required": ["bundleType", "bundlePath"],
            "properties": {
              "bundleType": { "const": "air-gapped" }
            }
          },
          "registry": {
            "required": ["endpoint", "namespace"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "environment": {
            "properties": {
              "type": { "const": "proxied" }
            }
          }
        }
      },
      "then": {
        "properties": {
          "environment": {
            "required": ["proxy"]
          }
        }
      }
    }
  ]
}
